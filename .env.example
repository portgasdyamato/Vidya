# Database Configuration (Neon PostgreSQL)
# Get your free database at: https://neon.tech
DATABASE_URL=

# Session Secret (for Express sessions)
SESSION_SECRET=

# OpenAI API Key (for GPT-4 Vision, Whisper, TTS)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API Key (alternative AI provider)
# Get your API key at: https://ai.google.dev/
GEMINI_API_KEY=

# Google OAuth (optional - for authentication)
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Base URL (optional - defaults to localhost:5000)
# BASE_URL=http://localhost:5000

# ─── ALTERNATIVE AI PROVIDER: OpenRouter ─────────────────────────────────────
# Get your API key at: https://openrouter.ai/
OPENROUTER_API_KEY=